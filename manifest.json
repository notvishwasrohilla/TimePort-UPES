{
  "manifest_version": 3,
  "name": "TimePort",
  "version": "0.5",
  "description": "Scrapes University Schedule and syncs to Google Calendar.",
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "oauth2": {
    "client_id": "Request ID from me please :D",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "action": {
    "default_popup": "popup.html"
  }
}
